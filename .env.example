# Secret for signing the session cookie. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# YNAB OAuth application (register one for free at app.ynab.com -> Account
# Settings -> Developer Settings -> OAuth Applications; set the redirect URI to
# <your origin>/oauth/ynab/callback). Required for users to connect their YNAB
# account via the "Connect to YNAB" button (OAuth is the only connection type).
#YNAB_CLIENT_ID=
#YNAB_CLIENT_SECRET=

# Public origin used to build the OAuth redirect URI when running behind a
# reverse proxy, e.g. https://fxforynab.example.com. Derived from the request
# when unset.
#PUBLIC_BASE_URL=

# Set true on the HTTPS deployment: marks the session cookie Secure and sends
# an HSTS header. Leave unset for local http development.
#SESSION_HTTPS_ONLY=true

# Where app.db (users, YNAB connections, conversions) is stored
# (default: ./data locally, /srv/data in Docker)
#DATA_DIR=data

# Legacy v1 single-user variables. APP_PASSWORD is read only by the one-shot
# migration `python -m app.import_legacy <email>`, which turns it into a real
# user account (see DEPLOY.md). YNAB_TOKEN is no longer used at all — the
# imported user reconnects via OAuth.
#APP_PASSWORD=
#YNAB_TOKEN=
