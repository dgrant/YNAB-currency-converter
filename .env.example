# Password for logging into the web UI (pick something strong)
APP_PASSWORD=change-me

# Secret for signing the session cookie. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# YNAB personal access token: app.ynab.com -> Account Settings -> Developer Settings
YNAB_TOKEN=

# Where conversions.json is stored (default: ./data locally, /srv/data in Docker)
#DATA_DIR=data
