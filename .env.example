# Secret for signing the session cookie. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Optional: YNAB OAuth application (register one for free at app.ynab.com ->
# Account Settings -> Developer Settings -> OAuth Applications; set the
# redirect URI to <your origin>/oauth/ynab/callback). When set, users get a
# "Connect to YNAB" button; otherwise each user pastes a personal access
# token on the Settings page.
#YNAB_CLIENT_ID=
#YNAB_CLIENT_SECRET=

# Public origin used to build the OAuth redirect URI when running behind a
# reverse proxy, e.g. https://ynabfx.example.com. Derived from the request
# when unset.
#PUBLIC_BASE_URL=

# Where app.db (users, YNAB connections, conversions) is stored
# (default: ./data locally, /srv/data in Docker)
#DATA_DIR=data

# Legacy v1 single-user variables. No longer used by the app itself — only
# read by the one-shot migration `python -m app.import_legacy <email>`,
# which turns them into a real user account (see DEPLOY.md).
#APP_PASSWORD=
#YNAB_TOKEN=
